#!/usr/bin/env bash
set -euo pipefail

main=$(git worktree list --porcelain | head -1 | cut -d' ' -f2)
here=$(git rev-parse --show-toplevel)

if [ "$main" = "$here" ]; then
    echo "Already in the main worktree, nothing to copy." >&2
    exit 0
fi

manifest="$here/.envrcs/.worktree-manifest"
mkdir -p "$here/.envrcs"
: > "$manifest"

# Read a config list (one path per line, '#' comments, blanks skipped, globs allowed).
read_paths() {
    local file="$1"
    [ -f "$file" ] || return 0
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [ -z "$line" ] && continue
        echo "$line"
    done < "$file"
}

# Copy paths listed in project/worktree-copies.txt (globs expanded against $main).
while IFS= read -r pattern; do
    [ -z "$pattern" ] && continue
    for f in "$main"/$pattern; do
        if [ -e "$f" ]; then
            rel="${f#$main/}"
            mkdir -p "$here/$(dirname "$rel")"
            cp -Pv "$f" "$here/$rel"
            echo "$rel" >> "$manifest"
        fi
    done
done < <(read_paths "$main/.devcontainer/project/worktree-copies.txt")

# Files that git opens with O_NOFOLLOW (symlinks cause ELOOP) — must be copies.
for target in .gitignore; do
    if [ -e "$main/$target" ] && [ ! -e "$here/$target" ]; then
        cp -v "$main/$target" "$here/$target"
        echo "$target" >> "$manifest"
    fi
done

# Symlink paths listed in project/worktree-symlinks.txt.
while IFS= read -r target; do
    [ -z "$target" ] && continue
    if [ -e "$main/$target" ] && [ ! -e "$here/$target" ]; then
        mkdir -p "$(dirname "$here/$target")"
        ln -sv "$main/$target" "$here/$target"
        echo "$target" >> "$manifest"
    fi
done < <(read_paths "$main/.devcontainer/project/worktree-symlinks.txt")

# Per-developer extras (gitignored).
while IFS= read -r target; do
    [ -z "$target" ] && continue
    if [ -e "$main/$target" ] && [ ! -e "$here/$target" ]; then
        mkdir -p "$(dirname "$here/$target")"
        ln -sv "$main/$target" "$here/$target"
        echo "$target" >> "$manifest"
    fi
done < <(read_paths "$main/.envrcs/.worktree-symlinks")

echo "Manifest written to .envrcs/.worktree-manifest"
echo "To remove: dev/cleanup-worktree"
