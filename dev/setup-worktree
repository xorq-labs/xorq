#!/usr/bin/env bash
set -euo pipefail

. "$(dirname "$0")/../.devcontainer/lib/git.sh"
main=$(dev_main_tree)
here=$(git rev-parse --show-toplevel)

if [ "$main" = "$here" ]; then
    echo "Already in the main worktree, nothing to copy." >&2
    exit 0
fi

manifest="$here/.envrcs/.worktree-manifest"
mkdir -p "$here/.envrcs"
: > "$manifest"
changes=0

. "$main/.devcontainer/lib/list-file.sh"

# `[ -e PATH ]` follows symlinks, so a broken symlink reads as "not present"
# and we'd try to create over it. `-L` catches the symlink itself.
is_present() { [ -e "$1" ] || [ -L "$1" ]; }

# Stale symlink (target gone) → remove so the create step below can heal it.
# Leaves real files/dirs and valid symlinks untouched.
heal_stale_symlink() {
    if [ -L "$1" ] && [ ! -e "$1" ]; then
        rm -v "$1"
        changes=$((changes + 1))
    fi
}

# Copy paths listed in project/worktree-copies.txt (globs expanded against $main).
# Patterns are interpreted as shell globs ONLY — the `for f in ...$pattern` loop
# leaves $pattern unquoted to allow `*`/`?`/`[...]` expansion. Shell substitutions
# (`$(...)`, backticks, `~`, `$VAR`) are not supported and not safe to use here;
# the file is treated as data, not script.
while IFS= read -r pattern; do
    [ -z "$pattern" ] && continue
    # Without `nullglob`, a non-matching glob expands to the literal pattern;
    # the `-e` check below filters that case (and broken symlinks) out.
    for f in "$main"/$pattern; do
        if [ -e "$f" ]; then
            rel="${f#$main/}"
            if ! is_present "$here/$rel"; then
                mkdir -p "$here/$(dirname "$rel")"
                cp -Pv "$f" "$here/$rel"
                changes=$((changes + 1))
            fi
            echo "$rel" >> "$manifest"
        fi
    done
done < <(read_list "$main/.devcontainer/project/worktree-copies.txt")

# .gitignore: git opens it with O_NOFOLLOW (a symlink would ELOOP) — must be a copy.
if [ -e "$main/.gitignore" ]; then
    if ! is_present "$here/.gitignore"; then
        cp -v "$main/.gitignore" "$here/.gitignore"
        changes=$((changes + 1))
    fi
    echo ".gitignore" >> "$manifest"
fi

link_from_main() {
    local target="$1"
    heal_stale_symlink "$here/$target"
    if [ -e "$main/$target" ]; then
        if ! is_present "$here/$target"; then
            mkdir -p "$(dirname "$here/$target")"
            ln -sv "$main/$target" "$here/$target"
            changes=$((changes + 1))
        fi
        echo "$target" >> "$manifest"
    fi
}

# .claude: audit logs and session captures must aggregate in the main checkout
# (devcontainer infrastructure, not project-specific) — always a symlink.
link_from_main ".claude"

# Symlink paths listed in project/worktree-symlinks.txt.
while IFS= read -r target; do
    [ -z "$target" ] && continue
    link_from_main "$target"
done < <(read_list "$main/.devcontainer/project/worktree-symlinks.txt")

# Per-developer extras (gitignored).
while IFS= read -r target; do
    [ -z "$target" ] && continue
    link_from_main "$target"
done < <(read_list "$main/.envrcs/.worktree-symlinks")

if [ "$changes" -gt 0 ]; then
    echo "Manifest written to .envrcs/.worktree-manifest"
    echo "To remove: dev/cleanup-worktree"
fi
