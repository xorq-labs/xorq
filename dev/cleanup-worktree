#!/usr/bin/env bash
set -euo pipefail

here=$(git rev-parse --show-toplevel)
main=$(git worktree list --porcelain | head -1 | cut -d' ' -f2)
manifest="$here/.envrcs/.worktree-manifest"

if [ ! -f "$manifest" ]; then
    echo "No manifest found at $manifest" >&2
    exit 1
fi

cd "$here"
xargs rm -v < "$manifest"
rm -v "$manifest"

cd "$main"
git worktree remove "$here"
