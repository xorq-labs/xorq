#!/usr/bin/env bash
set -euo pipefail

branch="${1:?usage: new-worktree <branch-name>}"
root=$(git rev-parse --show-toplevel)
project_env="$root/.devcontainer/project/project.env"
[ -f "$project_env" ] && . "$project_env"
: "${PROJECT_NAME:=$(basename "$root")}"
dest="$(dirname "$root")/${PROJECT_NAME}-${branch//\//-}"

git worktree add "$dest" "$branch" >&2
cd "$dest"
"$root/dev/setup-worktree" >&2
direnv allow >&2

echo "$dest"
