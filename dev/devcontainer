#!/usr/bin/env bash
set -euo pipefail

# Naming convention: DEV_* identifies dev-container infrastructure values
# (paths, IDs, flags) — used as the canonical name for both script-locals
# and exported env vars, Dockerfile build args, and compose interpolations.
# User-facing config in project.env keeps unprefixed names (PROJECT_NAME,
# MODEL_VERSION); they are translated to DEV_* on entry.

if [ "${1:-}" = "completions" ]; then
    shift
    exec "$(dirname "$0")/devcontainer-completions" "$@"
fi

if [ "$(uname -s)" != "Linux" ]; then
    echo "error: devcontainer requires Linux (uses GNU coreutils)" >&2
    exit 1
fi

while [[ "${1:-}" == -* ]]; do
    case "$1" in
        -w|--workspace)
            shift
            if [ $# -eq 0 ]; then
                echo "error: --workspace requires an argument" >&2
                exit 1
            fi
            DEV_WORKSPACE="$1"; shift ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

. "$(dirname "$0")/../.devcontainer/lib/git.sh"
DEV_MAIN_TREE="$(dev_main_tree)" || exit 1
export DEV_MAIN_TREE
COMPOSE_FILE="$DEV_MAIN_TREE/.devcontainer/docker-compose.yml"
COMPOSE_OVERRIDE="$DEV_MAIN_TREE/.devcontainer/project/compose.override.yml"

if [ ! -f "$COMPOSE_FILE" ]; then
    echo "error: $COMPOSE_FILE not found" >&2
    echo "The .devcontainer/ directory must exist in the main checkout: $DEV_MAIN_TREE" >&2
    exit 1
fi

# not configurable — compose, Dockerfile, and setup-claude all assume this path
DEV_CONTAINER_WORKSPACE="/workspaces/src"

DEV_WORKSPACE="${DEV_WORKSPACE:-.}"
_CMD="${1:-up}"

if [[ "$_CMD" =~ ^(down|reset|clean|status|logs)$ ]]; then
    if [ -d "$DEV_WORKSPACE" ]; then
        export DEV_WORKSPACE="$(cd "$DEV_WORKSPACE" && pwd)"
    else
        export DEV_WORKSPACE="$(readlink -m "$DEV_WORKSPACE")"
    fi
else
    if [ ! -d "$DEV_WORKSPACE" ]; then
        echo "error: workspace directory does not exist: $DEV_WORKSPACE" >&2
        exit 1
    fi
    export DEV_WORKSPACE="$(cd "$DEV_WORKSPACE" && pwd)"
fi

# Auto-resolve to git root when workspace is a subdirectory of a checkout.
# Mounting a subdirectory as the container workspace leaves /workspaces/src
# without a .git entry, so git (and tools like Claude Code) can't find the
# repo and fail with "not a git repository".
if [ -d "$DEV_WORKSPACE" ]; then
    _git_toplevel="$(git -C "$DEV_WORKSPACE" rev-parse --show-toplevel 2>/dev/null)" || {
        echo "error: $DEV_WORKSPACE is not inside a git repository" >&2
        exit 1
    }
    if [ "$DEV_WORKSPACE" != "$_git_toplevel" ]; then
        echo "note: resolving workspace to git root: $_git_toplevel (was: $DEV_WORKSPACE)" >&2
        export DEV_WORKSPACE="$_git_toplevel"
    fi
fi

# PROJECT_NAME scopes container names and shared volumes — must be consistent
# across worktrees, so always read from the main tree's project.env.
_main_project_env="$DEV_MAIN_TREE/.devcontainer/project/project.env"
[ -f "$_main_project_env" ] && . "$_main_project_env"
DEV_PROJECT_NAME="${PROJECT_NAME:-$(basename "$DEV_MAIN_TREE")}"
unset PROJECT_NAME
# MODEL_VERSION can vary per worktree. Re-source the workspace's copy
# (if different from main) so per-worktree overrides take effect.
if [ "$DEV_WORKSPACE" != "$DEV_MAIN_TREE" ]; then
    _ws_project_env="$DEV_WORKSPACE/.devcontainer/project/project.env"
    [ -f "$_ws_project_env" ] && . "$_ws_project_env"
    unset PROJECT_NAME
fi
[ -n "${MODEL_VERSION:-}" ] && export DEV_MODEL_VERSION="$MODEL_VERSION"
unset MODEL_VERSION
export DEV_UID="$(id -u)"
export DEV_GID="$(id -g)"
export DEV_MAIN_GIT="$DEV_MAIN_TREE/.git"
export DEV_HOST_USER="$(whoami)"
export DEV_PROJECT_NAME
export DEV_CONTAINER_WORKSPACE
# SSH and GPG agent forwarding: socat bridges the host agents into the
# container over TCP via host.docker.internal, so the container never
# bind-mounts the sockets directly.  `devcontainer refresh-ssh` and
# `devcontainer refresh-gpg` restart the respective bridges without
# rebuilding or restarting the container.  For tighter SSH control,
# use `ssh-add -c` (confirm each use) or load only the keys you need.

if [ -d "${HOME}/.config/sops/age" ]; then
    export DEV_SOPS_AGE_DIR="${HOME}/.config/sops/age"
else
    # mount an empty directory so the container sees a keyless dir, not a device file
    DEV_SOPS_AGE_DIR="/tmp/devcontainer-empty-sops-age"
    mkdir -p "$DEV_SOPS_AGE_DIR"
    export DEV_SOPS_AGE_DIR
    echo "warning: no sops age key found — sops-encrypted envrc secrets won't decrypt inside the container" >&2
fi

if [ "$DEV_WORKSPACE" = "$DEV_MAIN_TREE" ]; then
    export DEV_WORKTREE="main"
else
    export DEV_WORKTREE="$(basename "$DEV_WORKSPACE")"
fi

DEV_CONTAINER_NAME="${DEV_PROJECT_NAME}-dev-$(basename "$DEV_WORKSPACE")"
DEV_LOCKFILE="/tmp/devcontainer-${DEV_CONTAINER_NAME}.lock"

DEV_HAS_SOCAT=false
if command -v socat >/dev/null 2>&1; then
    DEV_HAS_SOCAT=true
fi

dc() {
    local files=(-f "$COMPOSE_FILE")
    [ -f "$COMPOSE_OVERRIDE" ] && files+=(-f "$COMPOSE_OVERRIDE")
    [ -n "${DEV_HOST_MOUNTS_OVERRIDE:-}" ] && files+=(-f "$DEV_HOST_MOUNTS_OVERRIDE")
    docker compose "${files[@]}" -p "$DEV_CONTAINER_NAME" "$@"
}

dc_exec() {
    dc exec \
        -e DEV_WORKTREE="$DEV_WORKTREE" \
        app "$@"
}

is_running() {
    dc ps --status running --format '{{.Service}}' 2>/dev/null | grep -q '^app$'
}

config_files() {
    local df="$DEV_MAIN_TREE/.devcontainer/Dockerfile"
    [ -f "$df" ] || { echo "error: $df not found" >&2; return 1; }
    printf '%s\n' \
        "$df" \
        "$COMPOSE_FILE" \
        "$DEV_MAIN_TREE/.devcontainer/setup-claude.py" \
        "$DEV_MAIN_TREE/.devcontainer/audit-hook" \
        "$DEV_MAIN_TREE/.devcontainer/project/install-system.sh" \
        "$DEV_MAIN_TREE/.devcontainer/project/setup-env.sh"
    [ -f "$COMPOSE_OVERRIDE" ] && printf '%s\n' "$COMPOSE_OVERRIDE"
    local hm
    for hm in \
        "$DEV_MAIN_TREE/.devcontainer/project/host-mounts.txt" \
        "$DEV_MAIN_TREE/.devcontainer/project/host-mounts.local.txt"; do
        [ -f "$hm" ] && printf '%s\n' "$hm"
    done
}

config_hash() {
    local files
    files="$(config_files)" || return 1
    {
        while IFS= read -r f; do
            cat "$f"
        done <<< "$files"
        # Build args interpolated into compose at build time are baked into
        # the image and don't show up in file-content hashing — include them
        # explicitly so a change forces rebuild. Anything else baked via env
        # interpolation must be added here.
        printf 'DEV_CONTAINER_WORKSPACE=%s\n' "$DEV_CONTAINER_WORKSPACE"
    } | sha256sum | cut -d' ' -f1
}

config_file_desc() {
    case "$(basename "$1")" in
        Dockerfile)            echo "base image, system packages" ;;
        docker-compose.yml)    echo "volumes, ports, orchestration" ;;
        compose.override.yml)  echo "project compose overrides" ;;
        setup-claude.py)       echo "Claude Code permissions and settings" ;;
        audit-hook)            echo "security audit hook" ;;
        install-system.sh)     echo "system package installation" ;;
        setup-env.sh)          echo "environment setup" ;;
        host-mounts.txt)       echo "host directory mounts" ;;
        host-mounts.local.txt) echo "local host mount overrides" ;;
        *)                     echo "" ;;
    esac
}

save_config_hashes() {
    config_files | while IFS= read -r f; do
        sha256sum "$f"
    done > "/tmp/devcontainer-${DEV_CONTAINER_NAME}.file-hashes"
}

show_config_changes() {
    local saved="/tmp/devcontainer-${DEV_CONTAINER_NAME}.file-hashes"
    if [ ! -f "$saved" ]; then
        echo "  (no baseline — cannot determine which files changed)"
        return
    fi
    local files
    files="$(config_files)" || return 1
    while IFS= read -r f; do
        local current_hash saved_hash desc
        current_hash="$(sha256sum "$f" | cut -d' ' -f1)"
        saved_hash="$(grep -F "  $f" "$saved" | head -1 | cut -d' ' -f1)"
        desc="$(config_file_desc "$f")"
        [ -n "$desc" ] && desc=" ($desc)"
        if [ -z "$saved_hash" ]; then
            printf '  + %s%s\n' "$(basename "$f")" "$desc"
        elif [ "$current_hash" != "$saved_hash" ]; then
            printf '  ~ %s%s\n' "$(basename "$f")" "$desc"
        fi
    done <<< "$files"
}

image_stale() {
    local container_id
    container_id="$(dc ps -q app 2>/dev/null | head -1)" || return 0
    [ -z "$container_id" ] && return 0

    local container_image tagged_image
    container_image="$(docker inspect --format '{{.Image}}' "$container_id")" || return 0
    tagged_image="$(docker image inspect --format '{{.ID}}' "${DEV_CONTAINER_NAME}:$(config_hash)" 2>/dev/null)" || return 0

    [ "$container_image" != "$tagged_image" ]
}

tag_image() {
    docker tag "$(dc images -q app)" "${DEV_CONTAINER_NAME}:$(config_hash)" \
        || echo "warning: could not tag image — staleness check will re-trigger next run" >&2
    save_config_hashes
}

require_tty() {
    if [ ! -t 0 ]; then
        echo "error: '$1' requires an interactive terminal (TTY)" >&2
        exit 1
    fi
}

# Generic host<->container bridge: SSH agent forwarding, host git/gh/Claude
# config copy. Defined separately so this script stays focused on orchestration.
. "$DEV_MAIN_TREE/.devcontainer/lib/host-bridge.sh"
. "$DEV_MAIN_TREE/.devcontainer/lib/list-file.sh"
. "$DEV_MAIN_TREE/.devcontainer/lib/host-mounts.sh"

generate_host_mounts_override

# Named-volume mount targets from the merged compose config — these come
# up root-owned and need chowning before user-mode setup runs. Deriving
# from compose means projects only declare volumes in compose.override.yml.
named_volume_targets() {
    local cfg
    cfg="$(dc config --format=json)" || {
        echo "error: 'docker compose config' failed — cannot derive named-volume mount targets" >&2
        return 1
    }
    printf '%s' "$cfg" | python3 -c '
import json, sys
cfg = json.load(sys.stdin)
for v in cfg.get("services", {}).get("app", {}).get("volumes") or []:
    if v.get("type") == "volume" and v.get("target"):
        print(v["target"])
'
}

# First-run setup: chown root-owned named-volume mount points, set up the
# host-path symlink for tools that persist absolute paths, then delegate
# to the project's setup-env first-run.
setup() {
    # Named volume mounts come up root-owned; fix targets and any parent
    # dirs auto-created by docker (e.g. /home/vscode/.cache when only
    # /home/vscode/.cache/uv is mounted). Ancestor walk is bounded to
    # /home/vscode/* — anything above is system-owned by design, and
    # workspace-rooted volumes' parents resolve into the host bind mount
    # (touching them would rewrite host-file ownership).
    #
    # Targets are passed via stdin (one per line) rather than interpolated
    # into the shell string so values from `docker compose config` can never
    # be parsed as shell metacharacters.
    named_volume_targets | dc exec -T -u root app sh -c '
        while IFS= read -r d; do
            [ -n "$d" ] || continue
            chown -R vscode:vscode "$d" 2>/dev/null || true
            p="$(dirname "$d")"
            while [ "$p" != "/" ] && [ "$p" != "." ]; do
                case "$p" in
                    /home/vscode/*) ;;
                    *) break ;;
                esac
                chown vscode:vscode "$p" 2>/dev/null || true
                p="$(dirname "$p")"
            done
        done
    '

    # Make the host workspace path resolvable inside the container.
    # Tools that persist absolute host paths (Nix gcroots, direnv state,
    # some build systems) fail when the host path doesn't exist in the
    # container. No-op when DEV_WORKSPACE == DEV_CONTAINER_WORKSPACE.
    # Also skipped when DEV_WORKSPACE == DEV_MAIN_TREE: the compose
    # volume DEV_MAIN_TREE:DEV_MAIN_TREE already bind-mounts the host
    # path as a real directory, so ln would descend into it and collide
    # with existing contents.
    #
    # Intermediate dirs created here may be root-owned when the host path
    # isn't under /home/$HOST_USER (which the Dockerfile already symlinks
    # into /home/vscode). Harmless — only the symlink itself is ever read.
    if [ "$DEV_WORKSPACE" != "$DEV_CONTAINER_WORKSPACE" ] \
        && [ "$DEV_WORKSPACE" != "$DEV_MAIN_TREE" ]; then
        dc exec -u root \
            -e DEV_WORKSPACE="$DEV_WORKSPACE" \
            -e DEV_CONTAINER_WORKSPACE="$DEV_CONTAINER_WORKSPACE" \
            app sh -c '
                mkdir -p "$(dirname "$DEV_WORKSPACE")"
                ln -sfn "$DEV_CONTAINER_WORKSPACE" "$DEV_WORKSPACE"
            '
    fi

    dc exec app setup-env first-run
    echo "Dev container ready: $DEV_CONTAINER_NAME"
}

# re-sync dependencies when lockfile changes — also project-defined
sync_if_needed() {
    dc_exec setup-env sync-if-needed
}

ensure_external_volumes() {
    while IFS= read -r name; do
        docker volume create "${DEV_PROJECT_NAME}-${name}" >/dev/null 2>&1 || true
    done < <(read_list "$DEV_MAIN_TREE/.devcontainer/project/external-volumes.txt")
}

ensure_up() {
    # Subshell scopes fd 9 so no child process can inherit the flock.
    (
        flock -n 9 || {
            echo "Another devcontainer operation is in progress, waiting..."
            flock 9
        }

        setup_claude_credentials
        install_hooks
        ensure_external_volumes
        if [ "$DEV_WORKSPACE" != "$DEV_MAIN_TREE" ]; then
            (cd "$DEV_WORKSPACE" && "$DEV_MAIN_TREE/dev/setup-worktree")
        fi

        if ! is_running; then
            dc up --build -d
            tag_image
            setup
        elif image_stale; then
            echo "Devcontainer config has changed since the container was built:"
            show_config_changes
            echo ""
            echo "  r) Rebuild container to apply changes"
            echo "  c) Continue with existing container"
            echo "  q) Quit"
            read -rp "Choice [r/c/q]: " answer
            case "$answer" in
                [rR]*)
                    dc down
                    dc up --build -d
                    tag_image
                    setup
                    ;;
                [qQ]*)
                    exit 2
                    ;;
                *)
                    echo "Continuing with existing container. Changes apply on next rebuild."
                    ;;
            esac
        fi

        setup_git
        setup_gh
        # Close flock fd so the backgrounded socat in setup_ssh_forward /
        # setup_gpg_forward doesn't inherit it and hold the lock after
        # the subshell exits.
        setup_ssh_forward 9>&-
        setup_gpg_forward 9>&-
        setup_claude
        sync_if_needed
    ) 9>"$DEV_LOCKFILE"
}

case "${1:-up}" in
    up)
        ensure_up
        ;;
    down)
        if is_running; then
            read -rp "Running container will be stopped. Continue? [y/N] " answer
            if [[ "$answer" != [yY]* ]]; then
                exit 0
            fi
        fi
        stop_ssh_forward
        stop_gpg_forward
        dc down
        ;;
    reset)
        read -rp "This will destroy the container and all volumes (venv, uv cache). Continue? [y/N] " answer
        if [[ "$answer" != [yY]* ]]; then
            exit 0
        fi
        stop_ssh_forward
        stop_gpg_forward
        dc down --volumes
        ;;
    clean)
        read -rp "This will destroy $DEV_CONTAINER_NAME (container, volumes, images, and host-side artifacts). Continue? [y/N] " answer
        if [[ "$answer" != [yY]* ]]; then
            exit 0
        fi
        stop_ssh_forward
        stop_gpg_forward
        dc down --volumes --rmi local
        docker images --format '{{.Repository}}:{{.Tag}}' \
            | grep "^${DEV_CONTAINER_NAME}:" \
            | xargs -r docker rmi 2>/dev/null || true
        rm -rf "$DEV_WORKSPACE/.claude/container-audit"
        rm -rf "$DEV_WORKSPACE/.claude/container-sessions"
        echo "Cleaned: $DEV_CONTAINER_NAME"
        ;;
    exec)
        shift
        if [ $# -eq 0 ]; then
            require_tty exec
            set -- bash
        fi
        ensure_up
        dc_exec "$@"
        ;;
    claude)
        shift
        require_tty claude
        ensure_up
        echo "Entering claude in $DEV_CONTAINER_NAME..."
        model_args=()
        [ -n "${DEV_MODEL_VERSION:-}" ] && model_args=(--model "$DEV_MODEL_VERSION")
        dc_exec claude "${model_args[@]}" "$@"
        ;;
    claude-dangerously-skip-permissions)
        shift
        require_tty claude-dangerously-skip-permissions
        ensure_up
        echo "Entering claude in $DEV_CONTAINER_NAME (--dangerously-skip-permissions)..."
        model_args=()
        [ -n "${DEV_MODEL_VERSION:-}" ] && model_args=(--model "$DEV_MODEL_VERSION")
        dc_exec claude --dangerously-skip-permissions "${model_args[@]}" "$@"
        ;;
    refresh-ssh)
        if ! is_running; then
            echo "error: container is not running" >&2
            exit 1
        fi
        setup_ssh_forward
        echo "SSH agent forwarded into $DEV_CONTAINER_NAME"
        ;;
    refresh-gpg)
        if ! is_running; then
            echo "error: container is not running" >&2
            exit 1
        fi
        setup_gpg_forward
        echo "GPG agent forwarded into $DEV_CONTAINER_NAME"
        ;;
    fix-credentials)
        if ! is_running; then
            echo "error: container is not running (start with 'devcontainer up' first)" >&2
            exit 1
        fi
        dc exec -u root app sh -c '
            rm -f /home/vscode/.claude/.credentials.json
            ln -s credentials/.credentials.json /home/vscode/.claude/.credentials.json
            chown -h vscode:vscode /home/vscode/.claude/.credentials.json
        '
        echo "Credentials symlink repaired in $DEV_CONTAINER_NAME"
        ;;
    audit)
        shift
        audit_log="$DEV_WORKSPACE/.claude/container-audit/audit.jsonl"
        if [ "${1:-}" = "--clear" ]; then
            rm -f "$audit_log"
            echo "Audit log cleared."
            exit 0
        fi
        if [ ! -f "$audit_log" ]; then
            echo "No audit log found at $audit_log"
            exit 0
        fi
        python3 "$DEV_MAIN_TREE/.devcontainer/audit-report.py" "$audit_log" "${1:---summary}"
        ;;
    status)
        if is_running; then
            echo "running: $DEV_CONTAINER_NAME (workspace: $DEV_WORKSPACE)"
        else
            echo "stopped"
        fi
        ;;
    logs)
        shift
        dc logs "$@"
        ;;
    *)
        cat >&2 <<'USAGE'
Usage: devcontainer [-w dir] <command>

Commands:
  up                                  start the dev container (default)
  down                                stop the dev container
  reset                               destroy container and all volumes
  clean                               reset + remove images and host-side artifacts
  status                              show whether the container is running
  logs [args...]                      show container logs
  exec [cmd...]                       run a command (default: bash)
  claude [args...]                    run claude
  claude-dangerously-skip-permissions run claude with --dangerously-skip-permissions
  refresh-ssh                         re-forward SSH agent (runs automatically on up/exec/claude;
                                        use standalone when agent changes mid-session)
  refresh-gpg                         re-forward GPG agent (runs automatically on up/exec/claude;
                                        use standalone when host gpg-agent restarts)
  fix-credentials                     repair credentials symlink in a running container
                                        (needed after upgrading from pre-shared-credentials build)
  audit [--summary|--new|--all|--clear]  show permission audit log (default: --summary)
  completions [bash|zsh|fish]         emit shell completions
USAGE
        exit 1
        ;;
esac
