#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" = "completions" ]; then
    shift
    exec "$(dirname "$0")/devcontainer-completions" "$@"
fi

if [ "$(uname -s)" != "Linux" ]; then
    echo "error: devcontainer requires Linux (uses GNU coreutils)" >&2
    exit 1
fi

while [[ "${1:-}" == -* ]]; do
    case "$1" in
        -w|--workspace)
            shift
            if [ $# -eq 0 ]; then
                echo "error: --workspace requires an argument" >&2
                exit 1
            fi
            DEV_WORKSPACE="$1"; shift ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

MAIN_TREE="$(git worktree list --porcelain | head -1 | sed 's/^worktree //')"
COMPOSE_FILE="$MAIN_TREE/.devcontainer/docker-compose.yml"
COMPOSE_OVERRIDE="$MAIN_TREE/.devcontainer/project/compose.override.yml"

if [ ! -f "$COMPOSE_FILE" ]; then
    echo "error: $COMPOSE_FILE not found" >&2
    echo "The .devcontainer/ directory must exist in the main checkout: $MAIN_TREE" >&2
    exit 1
fi

PROJECT_ENV="$MAIN_TREE/.devcontainer/project/project.env"
[ -f "$PROJECT_ENV" ] && . "$PROJECT_ENV"
PROJECT_NAME="${PROJECT_NAME:-$(basename "$MAIN_TREE")}"
# not configurable — compose, Dockerfile, and setup-claude all assume this path
CONTAINER_WORKSPACE="/workspaces/src"

DEV_WORKSPACE="${DEV_WORKSPACE:-.}"
_CMD="${1:-up}"

if [[ "$_CMD" =~ ^(down|reset|clean|status|logs)$ ]]; then
    if [ -d "$DEV_WORKSPACE" ]; then
        export DEV_WORKSPACE="$(cd "$DEV_WORKSPACE" && pwd)"
    else
        export DEV_WORKSPACE="$(readlink -m "$DEV_WORKSPACE")"
    fi
else
    if [ ! -d "$DEV_WORKSPACE" ]; then
        echo "error: workspace directory does not exist: $DEV_WORKSPACE" >&2
        exit 1
    fi
    export DEV_WORKSPACE="$(cd "$DEV_WORKSPACE" && pwd)"
fi
export DEV_UID="$(id -u)"
export DEV_GID="$(id -g)"
export DEV_MAIN_GIT="$MAIN_TREE/.git"
export DEV_MAIN_TREE="$MAIN_TREE"
export DEV_HOST_USER="$(whoami)"
export DEV_PROJECT_NAME="$PROJECT_NAME"
export DEV_CONTAINER_WORKSPACE="$CONTAINER_WORKSPACE"
[ -n "${MODEL_VERSION:-}" ] && export DEV_MODEL_VERSION="$MODEL_VERSION"
# SSH agent forwarding: socat bridges the host agent into the container
# over TCP via host.docker.internal, so the container never bind-mounts
# the socket directly.  `devcontainer refresh-ssh` restarts the bridge
# without touching the container.  For tighter control, use `ssh-add -c`
# (confirm each use) or load only the keys you need.

SOPS_AGE_DIR="${HOME}/.config/sops/age"
if [ -d "$SOPS_AGE_DIR" ]; then
    export DEV_SOPS_AGE_DIR="$SOPS_AGE_DIR"
else
    # mount an empty directory so the container sees a keyless dir, not a device file
    DEV_SOPS_AGE_EMPTY="/tmp/devcontainer-empty-sops-age"
    mkdir -p "$DEV_SOPS_AGE_EMPTY"
    export DEV_SOPS_AGE_DIR="$DEV_SOPS_AGE_EMPTY"
    echo "warning: no sops age key found — sops-encrypted envrc secrets won't decrypt inside the container" >&2
fi

if [ "$DEV_WORKSPACE" = "$MAIN_TREE" ]; then
    export DEV_WORKTREE="main"
else
    export DEV_WORKTREE="$(basename "$DEV_WORKSPACE")"
fi

CONTAINER_NAME="${PROJECT_NAME}-dev-$(basename "$DEV_WORKSPACE")"
LOCKFILE="/tmp/devcontainer-${CONTAINER_NAME}.lock"

HAS_SOCAT=false
if command -v socat >/dev/null 2>&1; then
    HAS_SOCAT=true
fi

dc() {
    local files=(-f "$COMPOSE_FILE")
    [ -f "$COMPOSE_OVERRIDE" ] && files+=(-f "$COMPOSE_OVERRIDE")
    docker compose "${files[@]}" -p "$CONTAINER_NAME" "$@"
}

dc_exec() {
    dc exec \
        -e DEV_WORKTREE="$DEV_WORKTREE" \
        app "$@"
}

is_running() {
    dc ps --status running --format '{{.Service}}' 2>/dev/null | grep -q '^app$'
}

config_hash() {
    local df="$MAIN_TREE/.devcontainer/Dockerfile"
    [ -f "$df" ] || { echo "error: $df not found" >&2; return 1; }
    local files=(
        "$df"
        "$COMPOSE_FILE"
        "$MAIN_TREE/.devcontainer/setup-claude.py"
        "$MAIN_TREE/.devcontainer/audit-hook"
        "$MAIN_TREE/.devcontainer/project/install-system.sh"
        "$MAIN_TREE/.devcontainer/project/setup-env.sh"
    )
    [ -f "$COMPOSE_OVERRIDE" ] && files+=("$COMPOSE_OVERRIDE")
    {
        cat "${files[@]}"
        # Build args interpolated into compose at build time are baked into
        # the image and don't show up in file-content hashing — include them
        # explicitly so a change forces rebuild. Anything else baked via env
        # interpolation must be added here.
        printf 'DEV_CONTAINER_WORKSPACE=%s\n' "$DEV_CONTAINER_WORKSPACE"
    } | sha256sum | cut -d' ' -f1
}

image_stale() {
    local container_id
    container_id="$(dc ps -q app 2>/dev/null | head -1)" || return 0
    [ -z "$container_id" ] && return 0

    local container_image tagged_image
    container_image="$(docker inspect --format '{{.Image}}' "$container_id")" || return 0
    tagged_image="$(docker image inspect --format '{{.ID}}' "${CONTAINER_NAME}:$(config_hash)" 2>/dev/null)" || return 0

    [ "$container_image" != "$tagged_image" ]
}

tag_image() {
    docker tag "$(dc images -q app)" "${CONTAINER_NAME}:$(config_hash)" \
        || echo "warning: could not tag image — staleness check will re-trigger next run" >&2
}

require_tty() {
    if [ ! -t 0 ]; then
        echo "error: '$1' requires an interactive terminal (TTY)" >&2
        exit 1
    fi
}

# Generic host<->container bridge: SSH agent forwarding, host git/gh/Claude
# config copy. Defined separately so this script stays focused on orchestration.
. "$MAIN_TREE/.devcontainer/lib/host-bridge.sh"
. "$MAIN_TREE/.devcontainer/lib/list-file.sh"

# Named-volume mount targets from the merged compose config — these come
# up root-owned and need chowning before user-mode setup runs. Deriving
# from compose means projects only declare volumes in compose.override.yml.
named_volume_targets() {
    local cfg
    cfg="$(dc config --format=json)" || {
        echo "error: 'docker compose config' failed — cannot derive named-volume mount targets" >&2
        return 1
    }
    printf '%s' "$cfg" | python3 -c '
import json, sys
cfg = json.load(sys.stdin)
for v in cfg.get("services", {}).get("app", {}).get("volumes") or []:
    if v.get("type") == "volume" and v.get("target"):
        print(v["target"])
'
}

# First-run setup: chown root-owned named-volume mount points, set up the
# host-path symlink for tools that persist absolute paths, then delegate
# to the project's setup-env first-run.
setup() {
    # Named volume mounts come up root-owned; fix targets and any parent
    # dirs auto-created by docker (e.g. /home/vscode/.cache when only
    # /home/vscode/.cache/uv is mounted). Ancestor walk is bounded to
    # /home/vscode/* — anything above is system-owned by design, and
    # workspace-rooted volumes' parents resolve into the host bind mount
    # (touching them would rewrite host-file ownership).
    #
    # Targets are passed via stdin (one per line) rather than interpolated
    # into the shell string so values from `docker compose config` can never
    # be parsed as shell metacharacters.
    named_volume_targets | dc exec -T -u root app sh -c '
        while IFS= read -r d; do
            [ -n "$d" ] || continue
            chown -R vscode:vscode "$d" 2>/dev/null || true
            p="$(dirname "$d")"
            while [ "$p" != "/" ] && [ "$p" != "." ]; do
                case "$p" in
                    /home/vscode/*) ;;
                    *) break ;;
                esac
                chown vscode:vscode "$p" 2>/dev/null || true
                p="$(dirname "$p")"
            done
        done
    '

    # Make the host workspace path resolvable inside the container.
    # Tools that persist absolute host paths (Nix gcroots, direnv state,
    # some build systems) fail when the host path doesn't exist in the
    # container. No-op when DEV_WORKSPACE == CONTAINER_WORKSPACE.
    # Also skipped when DEV_WORKSPACE == DEV_MAIN_TREE: the compose
    # volume DEV_MAIN_TREE:DEV_MAIN_TREE already bind-mounts the host
    # path as a real directory, so ln would descend into it and collide
    # with existing contents.
    #
    # Intermediate dirs created here may be root-owned when the host path
    # isn't under /home/$HOST_USER (which the Dockerfile already symlinks
    # into /home/vscode). Harmless — only the symlink itself is ever read.
    if [ "$DEV_WORKSPACE" != "$CONTAINER_WORKSPACE" ] \
        && [ "$DEV_WORKSPACE" != "$DEV_MAIN_TREE" ]; then
        dc exec -u root \
            -e DEV_WORKSPACE="$DEV_WORKSPACE" \
            -e CONTAINER_WORKSPACE="$CONTAINER_WORKSPACE" \
            app sh -c '
                mkdir -p "$(dirname "$DEV_WORKSPACE")"
                ln -sfn "$CONTAINER_WORKSPACE" "$DEV_WORKSPACE"
            '
    fi

    dc exec app setup-env first-run
    echo "Dev container ready: $CONTAINER_NAME"
}

# re-sync dependencies when lockfile changes — also project-defined
sync_if_needed() {
    dc_exec setup-env sync-if-needed
}

ensure_shared_volumes() {
    while IFS= read -r name; do
        docker volume create "${PROJECT_NAME}-${name}" >/dev/null 2>&1 || true
    done < <(read_list "$MAIN_TREE/.devcontainer/project/external-volumes.txt")
}

ensure_up() {
    # Subshell scopes fd 9 so no child process can inherit the flock.
    # Previous approach (exec 9>file / exec 9>&-) leaked fd 9 to long-lived
    # children like socat, holding the lock across invocations.
    (
        flock -n 9 || {
            echo "Another devcontainer operation is in progress, waiting..."
            flock 9
        }

        setup_claude_credentials
        ensure_shared_volumes

        if ! is_running; then
            dc up --build -d
            tag_image
            setup
        elif image_stale; then
            read -rp "Devcontainer config changed. Running container will be stopped. Continue? [y/N] " answer
            if [[ "$answer" != [yY]* ]]; then
                exit 0
            fi
            dc down
            dc up --build -d
            tag_image
            setup
        fi
    ) 9>"$LOCKFILE"

    setup_git
    setup_gh
    setup_ssh_forward
    setup_claude
    sync_if_needed
}

case "${1:-up}" in
    up)
        ensure_up
        ;;
    down)
        if is_running; then
            read -rp "Running container will be stopped. Continue? [y/N] " answer
            if [[ "$answer" != [yY]* ]]; then
                exit 0
            fi
        fi
        stop_ssh_forward
        dc down
        ;;
    reset)
        read -rp "This will destroy the container and all volumes (venv, uv cache). Continue? [y/N] " answer
        if [[ "$answer" != [yY]* ]]; then
            exit 0
        fi
        stop_ssh_forward
        dc down --volumes
        ;;
    clean)
        read -rp "This will destroy the container, volumes, images, and host-side artifacts. Continue? [y/N] " answer
        if [[ "$answer" != [yY]* ]]; then
            exit 0
        fi
        stop_ssh_forward
        dc down --volumes --rmi local
        docker images --format '{{.Repository}}:{{.Tag}}' \
            | grep "^${CONTAINER_NAME}:" \
            | xargs -r docker rmi 2>/dev/null || true
        rm -rf "$DEV_WORKSPACE/.claude/container-audit"
        rm -rf "$DEV_WORKSPACE/.claude/container-sessions"
        echo "Cleaned: $CONTAINER_NAME"
        ;;
    exec)
        shift
        if [ $# -eq 0 ]; then
            require_tty exec
            set -- bash
        fi
        ensure_up
        dc_exec "$@"
        ;;
    claude)
        shift
        require_tty claude
        ensure_up
        echo "Entering claude in $CONTAINER_NAME..."
        dc_exec claude "$@"
        ;;
    claude-dangerously-skip-permissions)
        shift
        require_tty claude-dangerously-skip-permissions
        ensure_up
        echo "Entering claude in $CONTAINER_NAME (--dangerously-skip-permissions)..."
        dc_exec claude --dangerously-skip-permissions "$@"
        ;;
    refresh-ssh)
        if ! is_running; then
            echo "error: container is not running" >&2
            exit 1
        fi
        setup_ssh_forward
        echo "SSH agent forwarded into $CONTAINER_NAME"
        ;;
    audit)
        shift
        audit_log="$DEV_WORKSPACE/.claude/container-audit/audit.jsonl"
        if [ "${1:-}" = "--clear" ]; then
            rm -f "$audit_log"
            echo "Audit log cleared."
            exit 0
        fi
        if [ ! -f "$audit_log" ]; then
            echo "No audit log found at $audit_log"
            exit 0
        fi
        python3 "$MAIN_TREE/.devcontainer/audit-report.py" "$audit_log" "${1:---summary}"
        ;;
    status)
        if is_running; then
            echo "running: $CONTAINER_NAME (workspace: $DEV_WORKSPACE)"
        else
            echo "stopped"
        fi
        ;;
    logs)
        shift
        dc logs "$@"
        ;;
    *)
        cat >&2 <<'USAGE'
Usage: devcontainer [-w dir] <command>

Commands:
  up                                  start the dev container (default)
  down                                stop the dev container
  reset                               destroy container and all volumes
  clean                               reset + remove images and host-side artifacts
  status                              show whether the container is running
  logs [args...]                      show container logs
  exec [cmd...]                       run a command (default: bash)
  claude [args...]                    run claude
  claude-dangerously-skip-permissions run claude with --dangerously-skip-permissions
  refresh-ssh                         re-forward SSH agent (runs automatically on up/exec/claude;
                                        use standalone when agent changes mid-session)
  audit [--summary|--new|--all|--clear]  show permission audit log (default: --summary)
  completions [bash|zsh|fish]         emit shell completions
USAGE
        exit 1
        ;;
esac
