{
  // per-project: container name
  "name": "xorq",
  // Tripwire: VS Code "Reopen in Container" / `devcontainer up` go through
  // this file but skip the bridge setup in dev/devcontainer (SSH agent,
  // Claude config, UID/GID match). dev/devcontainer drives docker compose
  // directly and never reads this file, so the exit only fires on the
  // unsupported path. See .devcontainer/README.md.
  "initializeCommand": "printf 'ERROR: use dev/devcontainer to start this container.\\nVS Code Reopen in Container / devcontainer CLI are unsupported.\\nSee .devcontainer/README.md.\\n' >&2; exit 1",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/src",
  "remoteUser": "vscode",
  // per-project: forwarded ports and labels
  "forwardPorts": [5432, 8080, 31337],
  "portsAttributes": {
    "5432": {"label": "PostgreSQL"},
    "8080": {"label": "Trino"},
    "31337": {"label": "GizmoSQL"}
  },
  // per-project: IDE extensions and settings
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "eamodio.gitlens",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/src/.venv/bin/python"
      }
    }
  }
}
